diff --git a/src/utils/openExternalLink.js b/src/utils/openExternalLink.js
new file mode 100644
index 0000000..ab2c4cd
--- /dev/null
+++ b/src/utils/openExternalLink.js
@@ -0,0 +1,19 @@
+export function openExternalLink(url) {
+  if (window.OverlayPluginApi && window.OverlayPluginApi.openUrlInBrowser) {
+    window.OverlayPluginApi.openUrlInBrowser(url);
+  } else {
+    window.open(url);
+  }
+}
+
+export function hookAllExternal() {
+  document.addEventListener('click', e => {
+    const el = e.target;
+    if (el.tagName === 'A') {
+      if (el.target === '_blank') {
+        openExternalLink(el.href);
+        e.preventDefault();
+      }
+    }
+  });
+}
